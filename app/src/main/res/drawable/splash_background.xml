<?xml version="1.0" encoding="utf-8"?>
<!-- Launch-window drawable. Black canvas with the HF brand logo
     centered. Compose takes over the moment MainActivity.onCreate
     fires; this exists to avoid the white flash before that. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/hf_background" />
        </shape>
    </item>
    <item
        android:drawable="@drawable/hf_brand_logo"
        android:gravity="center"
        android:width="180dp"
        android:height="180dp" />
</layer-list>
